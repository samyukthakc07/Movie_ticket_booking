DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=your-vm-public-ip
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-vm-public-ip
DJANGO_CORS_ALLOWED_ORIGINS=http://your-frontend-domain
DJANGO_CORS_ALLOW_CREDENTIALS=True
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
DJANGO_SECURE_SSL_REDIRECT=False
PUBLIC_APP_BASE_URL=http://your-frontend-domain
PUBLIC_API_BASE_URL=http://your-backend-domain
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.sendgrid.net
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=replace-me
DJANGO_EMAIL_HOST_PASSWORD=replace-me
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
RAZORPAY_KEY_ID=replace-me
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_WEBHOOK_SECRET=replace-me
DJANGO_LOG_LEVEL=INFO
