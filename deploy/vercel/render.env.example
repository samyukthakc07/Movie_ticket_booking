DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=your-render-service.onrender.com,your-frontend.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com,https://your-frontend.vercel.app
PUBLIC_APP_BASE_URL=https://your-frontend.vercel.app
PUBLIC_API_BASE_URL=https://your-frontend.vercel.app
DJANGO_SECURE_SSL_REDIRECT=True

# Optional if you ever call Render directly from the browser during testing.
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
DJANGO_CORS_ALLOW_CREDENTIALS=True
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
